{
	"$schema": "node_modules/@biomejs/biome/configuration_schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"formatter": {
		"enabled": true,
		"lineWidth": 120
	},
	"javascript": {
		"formatter": {
			"semicolons": "asNeeded",
			"trailingCommas": "all",
			"quoteStyle": "single",
			"arrowParentheses": "always"
		}
	},
	"linter": {
		"enabled": true
	},
	"files": {
		"includes": ["**", "!target", "!*.node", "!*.wasm", "!dist"]
	}
}
